{
  "manifest_version": 3,
  "name": "AI Video Call Helper",
  "version": "1.2.0",
  "description": "Real-time AI assistant for Google Meet and Zoom — works for any role or persona.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://app.zoom.us/*",
    "https://zoom.us/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.jpg",
      "48": "assets/icon48.jpg",
      "128": "assets/icon128.jpg"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": [
        "src/utils/constants.js",
        "src/utils/storage.js",
        "src/content/meet-captions.js",
        "src/content/sidebar.js",
        "src/content/content-script.js"
      ],
      "css": ["src/content/sidebar.css"]
    },
    {
      "matches": [
        "https://app.zoom.us/wc/*",
        "https://zoom.us/wc/*"
      ],
      "js": [
        "src/utils/constants.js",
        "src/utils/storage.js",
        "src/content/zoom-captions.js",
        "src/content/sidebar.js",
        "src/content/content-script.js"
      ],
      "css": ["src/content/sidebar.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/sidebar.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
